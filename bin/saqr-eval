#!/usr/bin/env php
<?php
declare(strict_types=1);

require __DIR__ . '/autoload.php';

use Saqr\Corpus;
use Saqr\Retriever;
use Saqr\Eval\Metrics;

$corpus = Corpus::loadFromFile(__DIR__ . '/../corpus/frameworks.json');
$retriever = new Retriever($corpus);
$m = new Metrics();

$rows = array_filter(array_map('trim', file(__DIR__ . '/../eval/questions.jsonl', FILE_IGNORE_NEW_LINES | FILE_SKIP_EMPTY_LINES)));

$agg = ['hit1' => 0.0, 'hit3' => 0.0, 'mrr' => 0.0, 'n' => 0];
$byLang = [];
foreach ($rows as $line) {
    $row = json_decode($line, true, 512, JSON_THROW_ON_ERROR);
    $ranked = array_values(array_filter(array_map(static fn ($e) => $e['id'] ?? null, $retriever->retrieveTopK($row['q'], 3))));
    $lang = $row['lang'] ?? 'en';
    $byLang[$lang] ??= ['hit1' => 0.0, 'hit3' => 0.0, 'mrr' => 0.0, 'n' => 0];
    foreach (['hit1' => fn() => $m->hitAtK($ranked, $row['expected_ids'], 1),
              'hit3' => fn() => $m->hitAtK($ranked, $row['expected_ids'], 3),
              'mrr' => fn() => $m->reciprocalRank($ranked, $row['expected_ids'])] as $key => $fn) {
        $v = $fn();
        $agg[$key] += $v;
        $byLang[$lang][$key] += $v;
    }
    $agg['n']++;
    $byLang[$lang]['n']++;
}

$fmt = static function (array $a): string {
    $n = max(1, $a['n']);
    return sprintf("hit@1=%.3f  hit@3=%.3f  MRR=%.3f  (n=%d)",
        $a['hit1'] / $n, $a['hit3'] / $n, $a['mrr'] / $n, $a['n']);
};

echo "Saqr retrieval eval\n===================\n";
echo "OVERALL  " . $fmt($agg) . "\n";
foreach ($byLang as $lang => $a) {
    echo "  [{$lang}]   " . $fmt($a) . "\n";
}
