#!/usr/bin/env php
<?php
declare(strict_types=1);

// Prefer Composer when installed; fall back to the hand-rolled autoloader.
$composer = __DIR__ . '/../vendor/autoload.php';
if (is_file($composer)) {
    require $composer;
} else {
    require __DIR__ . '/autoload.php';
}

// Read mode + dispatch.
$mode = $argv[1] ?? '';
switch ($mode) {
    case 'serve':
        require __DIR__ . '/serve.php';
        exit(0);
    case 'once':
        require __DIR__ . '/once.php';
        exit(0);
    default:
        fwrite(STDERR, json_encode([
            'ok' => false,
            'code' => 'BAD_REQUEST',
            'error' => 'Usage: saqr-cli {serve|once <cmd> [args...]}',
        ]) . "\n");
        exit(2);
}
