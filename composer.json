{
    "name": "cybersafe-lab/saqr",
    "description": "Grounded retrieval-augmented Q&A library for Saudi Arabia's cybersecurity and data-protection frameworks (PDPL, NCA-ECC, NCA-CCC, SAMA, ISO 27001).",
    "type": "library",
    "license": "Apache-2.0",
    "keywords": [
        "rag",
        "retrieval-augmented-generation",
        "cybersecurity",
        "compliance",
        "grc",
        "saudi-arabia",
        "pdpl",
        "nca-ecc",
        "sama",
        "iso27001",
        "anthropic",
        "claude"
    ],
    "authors": [
        {
            "name": "Mohammed AlYahya",
            "email": "security@malyahya.com",
            "homepage": "https://malyahya.com"
        }
    ],
    "require": {
        "php": "^8.2",
        "ext-json": "*",
        "ext-mbstring": "*"
    },
    "require-dev": {
        "pestphp/pest": "^3",
        "pestphp/pest-plugin-arch": "^3",
        "phpunit/phpunit": "^9.5 || ^10.0 || ^11.0"
    },
    "suggest": {
        "ext-curl": "Required for the bundled HTTP client used by Generator (Anthropic call)."
    },
    "autoload": {
        "psr-4": {
            "Saqr\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "Saqr\\Tests\\": "tests/"
        }
    },
    "scripts": {
        "lint": "find src -name '*.php' -print0 | xargs -0 -n1 php -l"
    },
    "minimum-stability": "stable",
    "config": {
        "sort-packages": true,
        "platform": {
            "php": "8.2.0"
        },
        "allow-plugins": {
            "pestphp/pest-plugin": true
        }
    }
}
